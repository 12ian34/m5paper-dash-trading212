# Trading 212 API credentials
# Get from Trading212 app → Settings → API
TRADING212_API_KEY=your_api_key
TRADING212_API_SECRET=your_api_secret

# WiFi credentials (must be 2.4 GHz — ESP32 doesn't support 5 GHz)
WIFI_SSID=your_wifi_ssid
WIFI_PASS=your_wifi_password

# URL where the Pi serves dashboard.json
DASHBOARD_URL=http://your-pi-ip:8080/dashboard.json
